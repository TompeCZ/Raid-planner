# Base URL pro OAuth redirecty (viz src/app/auth/callback/route.ts).
# V produkci nastavit na ostrou doménu (např. "https://raid-planner.example.com"),
# ne na IP adresu — jinak se nepoužije a spadne se zpět na origin z requestu.
